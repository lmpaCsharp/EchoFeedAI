# Copie este arquivo para .env e coloque sua chave real.
# Nunca envie o .env para o GitHub.
OPENROUTER_API_KEY=cole_sua_chave_aqui

# Modelo padrão: roteador gratuito da OpenRouter.
# Você pode trocar por outro modelo compatível com JSON Schema.
OPENROUTER_MODEL=openrouter/free

# Campos opcionais usados pela OpenRouter para identificar o app.
OPENROUTER_SITE_URL=http://localhost:5000
OPENROUTER_APP_TITLE=EchoFeed
